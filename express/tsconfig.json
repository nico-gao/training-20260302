{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "rootDir": ".",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "jest"]
  },
  "include": ["app.ts", "bin/**/*.ts", "controllers/**/*.ts", "middlewares/**/*.ts", "models/**/*.ts", "routes/**/*.ts", "services/**/*.ts", "tests/**/*.ts"]
}
